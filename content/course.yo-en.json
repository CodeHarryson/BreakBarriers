          "exercises": [
            {
              "type": "select_translation",
              "direction": "yo->en",
              "prompt": "ọkọ",
              "choices": ["husband", "vehicle", "spear", "hoe"],
              "answer": "husband",
              "vocabIds": ["oko-husband"],
              "note": "Mid–mid tone: ọkọ = husband. Tone changes the meaning!"
            },
            {
              "type": "select_translation",
              "direction": "yo->en",
              "prompt": "ọkọ̀",
              "choices": ["vehicle", "husband", "money", "market"],
              "answer": "vehicle",
              "vocabIds": ["oko-vehicle"],
              "note": "Mid–low tone: ọkọ̀ = vehicle/canoe. Compare ọkọ (husband)."
            },
            {
              "type": "select_translation",
              "direction": "yo->en",
              "prompt": "igbá",
              "choices": ["calabash", "time / season", "two hundred", "garden"],
              "answer": "calabash",
              "vocabIds": ["igba-calabash"],
              "note": "Mid–high: igbá = calabash."
            },
            {
              "type": "select_translation",
              "direction": "yo->en",
              "prompt": "ìgbà",
              "choices": ["time / season", "calabash", "rope", "basket"],
              "answer": "time / season",
              "vocabIds": ["igba-time"],
              "note": "Low–low: ìgbà = time. Same letters, different melody."
            },
            {
              "type": "match_pairs",
              "pairs": [
